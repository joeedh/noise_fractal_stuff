    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@shaderfrog/glsl-parser": "^0.1.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@typescript/native-preview": "latest",
    "esbuild": "^0.24.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
