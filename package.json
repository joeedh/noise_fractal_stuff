{
  "name": "noise_fractal_stuff",
  "version": "0.0.1",
  "description": "Fractal Explorer — browser/WebGL fractal & noise pattern explorer",
  "author": "Joseph Eagar",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
